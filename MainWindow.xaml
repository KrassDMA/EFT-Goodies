<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="EFT_Goodies.MainWindow"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EFT_Goodies"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="EFT Goodies">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top Row -->
            <RowDefinition Height="*"/>
            <!-- Splitter Row (Auto size is best practice) -->
            <RowDefinition Height="Auto" />
            <!-- Bottom Row -->
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <!-- Top Content -->
        <Border Grid.Row="0" Background="gray">
            <TextBlock Text="Map and radar are not yet implemented." HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Row Grid Splitter -->
        <controls:GridSplitter 
        Grid.Row="1" 
        Height="11" 
        HorizontalAlignment="Stretch" 
        ResizeBehavior="BasedOnAlignment" 
        ResizeDirection="Rows"
        Background="LightGray"
        Foreground="Gray" />

        <!-- Bottom Content -->
        <TextBox Grid.Row="2" x:Name="UiConsoleText" Background="black" Foreground="LightGray" BorderBrush="LightBlue" FontFamily="Consolas" IsReadOnly="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <TextBox.Resources>
                <!-- Set the hover and focused background to match your default background -->
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="black" />
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="black" />

                <!-- Optional: Also override border or foreground if needed -->
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="LightBlue" />
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="LightBlue" />
            </TextBox.Resources>
        </TextBox>
    </Grid>
</Window>
